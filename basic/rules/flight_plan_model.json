      "weight": 0.20,
      "direction": "positive",
      "is_veto": true,
      "scoring_rules": [
        { "condition": "无违规", "score": 100 },
        { "condition": "轻微违规", "score": 60 },
        { "condition": "侵入禁飞区", "score": 0 }
      ],
      "linked_rules": [
        { "dimension": "空域管理类", "rule_name": "空域分类与动态划设规则" }
      ]
    },
    {
      "seq": "F02",
      "dimension_id": "D1",
      "indicator_id": null,
