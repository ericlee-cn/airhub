{
  "model_id": "model_001",
  "model_name": "飞行计划评估模型",
  "scenario": "飞行计划评估",
  "description": "兼顾安全底线与收益效率，既防止风险又最大化运营效益的飞行计划综合评估模型。采用4+12核心指标集与组合赋权权重表。",
  "version": "1.0",
  "created_at": "2026-03-31",
  "scoring": {
    "formula": "总分 = Σ(指标得分 × 指标权重)",
    "max_score": 100,
    "grades": [
      { "grade": "A", "label": "最优计划", "min": 90, "max": 100, "color": "#22c55e", "action": "直接放行，优先执行" },
      { "grade": "B", "label": "合格计划", "min": 70, "max": 89, "color": "#eab308", "action": "需人工简要审核，确认无重大疏漏后执行" },
      { "grade": "C", "label": "不合格计划", "min": 0, "max": 69, "color": "#ef4444", "action": "系统自动驳回，要求重新规划航线" }
    ],
    "veto_indicators": ["F01"]
  },
  "dimensions": [
    { "id": "D1", "name": "核心安全维度", "color": "#ef4444", "weight_ratio": 0.50 },
    { "id": "D2", "name": "运营效率维度", "color": "#3b82f6", "weight_ratio": 0.13 },
    { "id": "D3", "name": "资源与成本维度", "color": "#10b981", "weight_ratio": 0.18 },
    { "id": "D4", "name": "风险与应急维度", "color": "#f59e0b", "weight_ratio": 0.12 },
    { "id": "D5", "name": "政策与合规维度", "color": "#8b5cf6", "weight_ratio": 0.07 }
  ],
  "indicators": [
