      "weight": 0.15,
      "direction": "positive",
      "is_veto": false,
      "scoring_rules": [
        { "condition": "极佳", "score": 100 },
        { "condition": "适宜", "score": 75 },
        { "condition": "不适宜", "score": 30 }
